{
    "name": "flowcast",
    "version": "1.0.0",
    "description": "Browser-first media format converter with a self-hosted MP3 encoder",
    "main": "./dist/esm/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/esm/index.js",
            "default": "./dist/esm/index.js"
        },
        "./browser": "./dist/FlowCast.min.js",
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "node scripts/build.mjs",
        "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
        "check": "tsc --noEmit",
        "verify": "npm run verify:audio && npm run verify:media",
        "verify:audio": "node test/verify-mp2.mjs && node test/verify-mp3.mjs && node test/verify-mpeg-decode.mjs && node test/verify-flac-enc.mjs && node test/verify-aac-enc.mjs",
        "verify:media": "node test/verify-mux.mjs && node test/verify-gif.mjs",
        "bench:mp3": "node test/bench-mp3.mjs"
    },
    "license": "WTFPL",
    "devDependencies": {
        "typescript": "^5.7.3"
    },
    "type": "module",
    "module": "./dist/esm/index.js",
    "browser": "./dist/FlowCast.min.js",
    "files": [
        "dist",
        "README.md"
    ]
}
